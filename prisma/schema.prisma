generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id                     Int                     @id @default(autoincrement())
  email                  String                  @unique
  password               String
  firstName              String?
  lastName               String?
  phoneNumber            String?
  dateOfBirth            DateTime?
  role                   String                  @default("student")
  isVerified             Boolean                 @default(false)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime?               @updatedAt
  isDestroyed            Boolean                 @default(false)
  verifyToken            String?
  resetPasswordExpires   DateTime?
  resetPasswordToken     String?
  avatarId               Int?                    @unique
  authorBlockedUsers     AuthorBannedUser[]      @relation("AuthorBlocker")
  bannedFromAuthors      AuthorBannedUser[]      @relation("AuthorBlocked")
  blogComments           BlogComment[]
  blogPosts              BlogPost[]              @relation("AuthorPosts")
  reviewedBlogPosts      BlogPost[]              @relation("ReviewedPosts")
  cart                   Cart?
  lastSentConversations  Conversation[]          @relation("ConversationLastMessageSender")
  lecturerConversations  Conversation[]          @relation("LecturerConversations")
  studentConversations   Conversation[]          @relation("StudentConversations")
  memberConversations    ConversationMember[]
  couponUsages           CouponUsage[]
  courses                Course[]                @relation("LecturerCourses")
  reviews                CourseReview[]
  enrollments            Enrollment[]
  keyToken               KeyToken?
  lecturerPayout         LecturerPayout[]
  lecturerPayoutAccounts LecturerPayoutAccount[]
  lecturerProfile        LecturerProfile?
  sentMessages           Message[]               @relation("MessageSender")
  notifications          Notification[]
  orders                 Order[]
  revenues               Revenue[]
  submissions            Submission[]
  transactions           Transaction[]
  avatar                 Resource?               @relation("UserAvatar", fields: [avatarId], references: [id])
  wishlist               Wishlist[]
}

model KeyToken {
  id               Int      @id @default(autoincrement())
  userId           Int      @unique
  publicKey        String
  privateKey       String
  refreshToken     String?  @db.Text
  createdAt        DateTime @default(now())
  isDestroyed      Boolean  @default(false)
  refreshTokenUsed Json
  updatedAt        DateTime @updatedAt
  kid              String
  user             User     @relation(fields: [userId], references: [id])
}

model Role {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  permissions Json
  inherits    Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @updatedAt
  isDestroyed Boolean   @default(false)
}

model Course {
  id            Int             @id @default(autoincrement())
  lecturerId    Int
  categoryId    Int?
  name          String
  lecturerName  String?
  duration      String?
  totalStudents Int             @default(0)
  totalLessons  Int             @default(0)
  totalQuizzes  Int             @default(0)
  level         String?
  overview      String?
  price         Float           @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime?       @updatedAt
  isDestroyed   Boolean         @default(false)
  status        String          @default("draft")
  thumbnailId   Int?            @unique
  introVideoId  Int?            @unique
  assessments   Assessment[]
  cartItems     CartItem[]
  coupons       Coupon[]
  category      CourseCategory? @relation(fields: [categoryId], references: [id])
  introVideo    Resource?       @relation("CourseIntroVideo", fields: [introVideoId], references: [id])
  lecturer      User            @relation("LecturerCourses", fields: [lecturerId], references: [id])
  thumbnail     Resource?       @relation("CourseThumbnail", fields: [thumbnailId], references: [id])
  courseFAQs    CourseFAQ[]
  reviews       CourseReview[]
  enrollments   Enrollment[]
  modules       Module[]
  orderItems    OrderItem[]
  revenues      Revenue[]
  wishlists     Wishlist[]

  @@index([categoryId], map: "Course_categoryId_fkey")
  @@index([lecturerId], map: "Course_lecturerId_fkey")
}

model CourseCategory {
  id          Int       @id @default(autoincrement())
  name        String
  slug        String    @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @updatedAt
  isDestroyed Boolean   @default(false)
  courses     Course[]
}

model CourseFAQ {
  id          Int       @id @default(autoincrement())
  question    String    @db.Text
  answer      String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @updatedAt
  isDestroyed Boolean   @default(false)
  courseId    Int
  course      Course    @relation(fields: [courseId], references: [id])

  @@index([courseId], map: "CourseFAQ_courseId_fkey")
}

model CourseReview {
  id            Int       @id @default(autoincrement())
  courseId      Int
  studentId     Int
  studentName   String?
  studentAvatar String?
  rating        Int
  content       String?
  lecturerReply String?   @db.Text
  lecturerReplyAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime? @updatedAt
  isDestroyed   Boolean   @default(false)
  course        Course    @relation(fields: [courseId], references: [id])
  student       User      @relation(fields: [studentId], references: [id])

  @@index([courseId], map: "CourseReview_courseId_fkey")
  @@index([studentId], map: "CourseReview_studentId_fkey")
}

model Module {
  id           Int       @id @default(autoincrement())
  courseId     Int
  title        String
  description  String?
  duration     String?
  totalLessons Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime? @updatedAt
  isDestroyed  Boolean   @default(false)
  lessons      Lesson[]
  course       Course    @relation(fields: [courseId], references: [id])

  @@index([courseId], map: "Module_courseId_fkey")
}

model Lesson {
  id            Int          @id @default(autoincrement())
  moduleId      Int
  title         String
  description   String?
  note          String?
  duration      String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime?    @updatedAt
  isDestroyed   Boolean      @default(false)
  lessonFileId  Int?         @unique
  lessonVideoId Int?         @unique
  assessments   Assessment[]
  lessonFile    Resource?    @relation("LessonFile", fields: [lessonFileId], references: [id])
  lessonVideo   Resource?    @relation("LessonVideo", fields: [lessonVideoId], references: [id])
  module        Module       @relation(fields: [moduleId], references: [id])
  quizzes       Quiz[]

  @@index([moduleId], map: "Lesson_moduleId_fkey")
}

model Resource {
  id                  Int              @id @default(autoincrement())
  fileSize            Int?
  fileType            String?
  fileUrl             String
  createdAt           DateTime         @default(now())
  updatedAt           DateTime?        @updatedAt
  isDestroyed         Boolean          @default(false)
  publicId            String           @unique
  blogThumbnail       BlogPost?        @relation("BlogThumbnail")
  courseIntroVideo    Course?          @relation("CourseIntroVideo")
  courseThumbnail     Course?          @relation("CourseThumbnail")
  lecturerProfileFile LecturerProfile? @relation("LecturerProfileFile")
  lessonFile          Lesson?          @relation("LessonFile")
  lessonVideo         Lesson?          @relation("LessonVideo")
  userAvatar          User?            @relation("UserAvatar")
}

model Enrollment {
  id             Int       @id @default(autoincrement())
  studentId      Int
  courseId       Int
  status         String    @default("enrolled")
  progress       Float     @default(0)
  lastAccessedAt DateTime?
  createdAt      DateTime  @default(now())
  isDestroyed    Boolean   @default(false)
  course         Course    @relation(fields: [courseId], references: [id])
  student        User      @relation(fields: [studentId], references: [id])

  @@index([courseId], map: "Enrollment_courseId_fkey")
  @@index([studentId], map: "Enrollment_studentId_fkey")
}

model Quiz {
  id           Int          @id @default(autoincrement())
  lessonId     Int
  title        String
  description  String?
  timeLimit    Int?
  passingScore Int?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime?    @updatedAt
  isDestroyed  Boolean      @default(false)
  questions    Question[]
  lesson       Lesson       @relation(fields: [lessonId], references: [id])
  submissions  Submission[]

  @@index([lessonId], map: "Quiz_lessonId_fkey")
}

model Question {
  id            Int       @id @default(autoincrement())
  quizId        Int
  question      String
  type          String
  options       Json?
  correctAnswer String?
  point         Int?      @default(1)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime? @updatedAt
  isDestroyed   Boolean   @default(false)
  quiz          Quiz      @relation(fields: [quizId], references: [id])

  @@index([quizId], map: "Question_quizId_fkey")
}

model Order {
  id             Int          @id @default(autoincrement())
  studentId      Int
  lecturer       String?
  totalPrice     Float?       @default(0)
  paymentMethod  String?      @default("payos")
  status         String?      @default("pending")
  createdAt      DateTime     @default(now())
  isDestroyed    Boolean      @default(false)
  checkoutUrl    String?      @db.Text
  isSuccess      Boolean      @default(false)
  paymentLinkId  String?      @unique
  paymentStatus  String?      @default("pending")
  qrCode         String?      @db.Text
  updatedAt      DateTime?    @updatedAt
  couponCode     String?
  couponId       Int?
  discountAmount Float?       @default(0)
  originalPrice  Float?
  couponUsage    CouponUsage?
  coupon         Coupon?      @relation(fields: [couponId], references: [id])
  student        User         @relation(fields: [studentId], references: [id])
  items          OrderItem[]
  revenue        Revenue?

  @@index([couponId], map: "Order_couponId_fkey")
  @@index([studentId], map: "Order_studentId_fkey")
}

model OrderItem {
  id          Int      @id @default(autoincrement())
  orderId     Int
  courseId    Int
  price       Float?
  lecturerId  Int?
  createdAt   DateTime @default(now())
  isDestroyed Boolean  @default(false)
  course      Course   @relation(fields: [courseId], references: [id])
  order       Order    @relation(fields: [orderId], references: [id])

  @@unique([orderId, courseId])
  @@index([courseId], map: "OrderItem_courseId_fkey")
}

model Coupon {
  id              Int             @id @default(autoincrement())
  name            String
  description     String?
  status          String?         @default("active")
  code            String          @unique
  categoryId      Int?
  amount          Float?
  startingDate    DateTime?
  startingTime    String?
  endingDate      DateTime?
  endingTime      String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime?       @updatedAt
  isDestroyed     Boolean         @default(false)
  courseId        Int?
  discount        Float?
  discountUnit    String?         @default("percent")
  usageLimit      Int?
  minOrderValue   Float?
  maxValue        Float?
  scope           String          @default("ALL_COURSES")
  scopeCategoryId Int?
  usagePerUser    Int?
  usedCount       Int             @default(0)
  category        CouponCategory? @relation(fields: [categoryId], references: [id])
  course          Course?         @relation(fields: [courseId], references: [id])
  usages          CouponUsage[]
  orders          Order[]

  @@index([categoryId], map: "Coupon_categoryId_fkey")
  @@index([courseId], map: "Coupon_courseId_fkey")
}

model CouponUsage {
  id       Int      @id @default(autoincrement())
  couponId Int
  userId   Int
  orderId  Int      @unique
  usedAt   DateTime @default(now())
  coupon   Coupon   @relation(fields: [couponId], references: [id])
  order    Order    @relation(fields: [orderId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@index([couponId])
  @@index([userId, couponId])
}

model CouponCategory {
  id          Int       @id @default(autoincrement())
  name        String
  slug        String    @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @updatedAt
  isDestroyed Boolean   @default(false)
  coupons     Coupon[]
}

model Submission {
  id           Int        @id @default(autoincrement())
  assessmentId Int
  quizId       Int
  studentId    Int
  score        Float?
  status       String?
  submittedAt  DateTime?
  isDestroyed  Boolean?   @default(false)
  feedback     String?
  assessment   Assessment @relation(fields: [assessmentId], references: [id])
  quiz         Quiz       @relation(fields: [quizId], references: [id])
  student      User       @relation(fields: [studentId], references: [id])

  @@index([assessmentId], map: "Submission_assessmentId_fkey")
  @@index([quizId], map: "Submission_quizId_fkey")
  @@index([studentId], map: "Submission_studentId_fkey")
}

model Assessment {
  id               Int          @id @default(autoincrement())
  courseId         Int
  lessonId         Int?
  title            String
  type             String?
  dueDate          DateTime?
  status           String?
  totalSubmissions Int?
  averageScore     Float?
  createdAt        DateTime     @default(now())
  isDestroyed      Boolean      @default(false)
  updatedAt        DateTime     @updatedAt
  course           Course       @relation(fields: [courseId], references: [id])
  lesson           Lesson?      @relation(fields: [lessonId], references: [id])
  submissions      Submission[]

  @@index([courseId], map: "Assessment_courseId_fkey")
  @@index([lessonId], map: "Assessment_lessonId_fkey")
}

model BlogPost {
  id            Int           @id @default(autoincrement())
  authorId      Int
  categoryId    Int?
  title         String
  slug          String?
  content       String?       @db.LongText
  totalComments Int?          @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime?     @updatedAt
  isDestroyed   Boolean       @default(false)
  thumbnailId   Int?          @unique
  reviewedById  Int?
  status        String        @default("draft")
  reviewNote    String?
  publishedAt   DateTime?
  comments      BlogComment[]
  author        User          @relation("AuthorPosts", fields: [authorId], references: [id])
  category      BlogCategory? @relation(fields: [categoryId], references: [id])
  reviewedBy    User?         @relation("ReviewedPosts", fields: [reviewedById], references: [id])
  thumbnail     Resource?     @relation("BlogThumbnail", fields: [thumbnailId], references: [id])

  @@index([authorId], map: "BlogPost_authorId_fkey")
  @@index([categoryId], map: "BlogPost_categoryId_fkey")
  @@index([reviewedById])
}

model BlogCategory {
  id          Int        @id @default(autoincrement())
  name        String
  slug        String     @unique
  createdAt   DateTime   @default(now())
  updatedAt   DateTime?  @updatedAt
  isDestroyed Boolean    @default(false)
  posts       BlogPost[]
}

model BlogComment {
  id          Int           @id @default(autoincrement())
  blogId      Int
  userId      Int
  content     String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime?     @updatedAt
  isDestroyed Boolean       @default(false)
  parentId    Int?
  post        BlogPost      @relation(fields: [blogId], references: [id])
  parent      BlogComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  children    BlogComment[] @relation("CommentReplies")
  user        User          @relation(fields: [userId], references: [id])

  @@index([blogId], map: "BlogComment_blogId_fkey")
  @@index([parentId], map: "BlogComment_parentId_fkey")
  @@index([userId], map: "BlogComment_userId_fkey")
}

model Wishlist {
  id              Int       @id @default(autoincrement())
  userId          Int
  courseId        Int
  courseThumbnail String?
  courseName      String?
  lecturer        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime? @updatedAt
  isDestroyed     Boolean   @default(false)
  course          Course    @relation(fields: [courseId], references: [id])
  user            User      @relation(fields: [userId], references: [id])

  @@unique([userId, courseId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([courseId], map: "Wishlist_courseId_fkey")
  @@index([userId], map: "Wishlist_userId_fkey")
}

model Cart {
  id          Int        @id @default(autoincrement())
  userId      Int        @unique
  courseName  String?
  lecturer    String?
  createdAt   DateTime   @default(now())
  isDestroyed Boolean    @default(false)
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id])
  items       CartItem[]
}

model CartItem {
  id        Int      @id @default(autoincrement())
  cartId    Int
  courseId  Int
  price     Float
  createdAt DateTime @default(now())
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id])

  @@unique([cartId, courseId])
  @@index([courseId], map: "CartItem_courseId_fkey")
}

model Transaction {
  id                  Int                  @id @default(autoincrement())
  userId              Int
  userRole            String?
  amount              Float?
  paymentMethod       String?
  status              String?
  gatewayReference    String?
  createdAt           DateTime             @default(now())
  isDestroyed         Boolean              @default(false)
  user                User                 @relation(fields: [userId], references: [id])
  studentTransactions TransactionStudent[]

  @@index([userId], map: "Transaction_userId_fkey")
}

model TransactionStudent {
  id             Int         @id @default(autoincrement())
  transactionId  Int
  orderId        Int?
  courseId       Int?
  isDiscount     Boolean?    @default(false)
  discountAmount Float?
  discountCode   String?
  createdAt      DateTime    @default(now())
  isDestroyed    Boolean     @default(false)
  transaction    Transaction @relation(fields: [transactionId], references: [id])

  @@index([transactionId], map: "TransactionStudent_transactionId_fkey")
}

model LecturerProfile {
  id                Int       @id @default(autoincrement())
  lecturerId        Int       @unique
  gender            String?
  nationality       String?
  professionalTitle String?
  beginStudies      DateTime?
  highestDegree     String?
  totalStudents     Int?
  totalCourses      Int?
  avgRating         Float?
  bio               String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime? @updatedAt
  isDestroyed       Boolean   @default(false)
  isActive          Boolean   @default(false)
  lecturerFileId    Int?      @unique
  lecturerFile      Resource? @relation("LecturerProfileFile", fields: [lecturerFileId], references: [id])
  lecturer          User      @relation(fields: [lecturerId], references: [id])
}

model LecturerPayout {
  id              Int       @id @default(autoincrement())
  transactionId   Int?
  lecturerId      Int
  payoutAccountId Int?
  currency        String?
  amount          Float?
  payoutMethod    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime? @updatedAt
  isDestroyed     Boolean   @default(false)
  status          String    @default("success")
  lecturer        User      @relation(fields: [lecturerId], references: [id])

  @@index([lecturerId], map: "LecturerPayout_lecturerId_fkey")
}

model LecturerPayoutAccount {
  id             Int       @id @default(autoincrement())
  lecturerId     Int
  cardType       String?
  cardNumber     String?
  cardExpireDate DateTime?
  cardCVV        Int?
  cardHolderName String?
  isDefault      Boolean?  @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime? @updatedAt
  isDestroyed    Boolean   @default(false)
  lecturer       User      @relation(fields: [lecturerId], references: [id])

  @@index([lecturerId], map: "LecturerPayoutAccount_lecturerId_fkey")
}

model Revenue {
  id           Int      @id @default(autoincrement())
  orderId      Int      @unique
  lecturerId   Int?
  courseId     Int
  totalAmount  Float
  platformFee  Float
  lecturerEarn Float
  createdAt    DateTime @default(now())
  course       Course   @relation(fields: [courseId], references: [id])
  lecturer     User?    @relation(fields: [lecturerId], references: [id])
  order        Order    @relation(fields: [orderId], references: [id])

  @@index([courseId], map: "Revenue_courseId_fkey")
  @@index([lecturerId], map: "Revenue_lecturerId_fkey")
}

model Notification {
  id          Int      @id @default(autoincrement())
  userId      Int
  title       String
  message     String   @db.Text
  type        String   @default("info")
  relatedId   Int?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  isDestroyed Boolean  @default(false)
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

model Conversation {
  id                  Int                  @id @default(autoincrement())
  studentId           Int
  lecturerId          Int
  lastMessageId       Int?                 @unique
  lastMessageSenderId Int?
  lastMessageContent  String?              @db.Text
  lastMessageAt       DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  isDestroyed         Boolean              @default(false)
  lastMessage         Message?             @relation("ConversationLastMessage", fields: [lastMessageId], references: [id])
  lastMessageSender   User?                @relation("ConversationLastMessageSender", fields: [lastMessageSenderId], references: [id])
  lecturer            User                 @relation("LecturerConversations", fields: [lecturerId], references: [id])
  student             User                 @relation("StudentConversations", fields: [studentId], references: [id])
  members             ConversationMember[]
  messages            Message[]

  @@unique([studentId, lecturerId])
  @@index([studentId, lastMessageAt(sort: Desc)])
  @@index([lecturerId, lastMessageAt(sort: Desc)])
  @@index([lastMessageAt(sort: Desc)])
  @@index([lastMessageSenderId], map: "Conversation_lastMessageSenderId_fkey")
}

model ConversationMember {
  conversationId    Int
  userId            Int
  role              ConversationRole
  unreadCount       Int              @default(0)
  joinedAt          DateTime         @default(now())
  lastReadAt        DateTime?
  lastSeenMessageId Int?
  conversation      Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  lastSeenMessage   Message?         @relation("MemberLastSeenMessage", fields: [lastSeenMessageId], references: [id])
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId, conversationId])
  @@index([userId, unreadCount])
  @@index([lastSeenMessageId], map: "ConversationMember_lastSeenMessageId_fkey")
}

model Message {
  id                   Int                  @id @default(autoincrement())
  conversationId       Int
  senderId             Int
  content              String?              @db.Text
  imgUrl               String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  isDestroyed          Boolean              @default(false)
  asLastOfConversation Conversation?        @relation("ConversationLastMessage")
  seenByMembers        ConversationMember[] @relation("MemberLastSeenMessage")
  conversation         Conversation         @relation(fields: [conversationId], references: [id])
  sender               User                 @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt(sort: Desc)])
  @@index([senderId, createdAt(sort: Desc)])
}

model AuthorBannedUser {
  id        Int      @id @default(autoincrement())
  authorId  Int
  userId    Int
  createdAt DateTime @default(now())
  author    User     @relation("AuthorBlocker", fields: [authorId], references: [id])
  user      User     @relation("AuthorBlocked", fields: [userId], references: [id])

  @@unique([authorId, userId])
  @@index([userId], map: "AuthorBannedUser_userId_fkey")
}

enum ConversationRole {
  STUDENT
  LECTURER
}
